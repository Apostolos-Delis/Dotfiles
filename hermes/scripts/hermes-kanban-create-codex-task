#!/usr/bin/env bash

set -euo pipefail

ASSIGNEE="codex-worker"
BOARD=""
BODY=""
BODY_FILE=""
BRANCH=""
MAX_RUNTIME="2h"
GOAL=false
GOAL_MAX_TURNS=""
PRIORITY=""
IDEMPOTENCY_KEY=""

usage() {
    cat <<'EOF'
Usage: hermes-kanban-create-codex-task [OPTIONS] "task title"

Create a Hermes Kanban coding task in the current git repository using a fresh
worktree and the Codex PR lane skills.

Options:
  --assignee NAME        Hermes profile assignee. Default: codex-worker.
  --board SLUG           Target Kanban board.
  --body TEXT            Extra task body / acceptance criteria.
  --body-file PATH       Read extra task body from a file.
  --branch NAME          Branch for the worktree task.
  --max-runtime VALUE    Runtime cap, e.g. 30m, 2h. Default: 2h.
  --goal                 Enable Kanban goal mode.
  --goal-max-turns N     Goal-mode turn budget.
  --priority N           Kanban priority.
  --idempotency-key KEY  Deduplicate automated task creation.
  -h, --help             Show this help.
EOF
}

slugify() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//' \
        | cut -c1-48
}

while [ $# -gt 0 ]; do
    case "$1" in
        --assignee)
            ASSIGNEE="$2"
            shift 2
            ;;
        --board)
            BOARD="$2"
            shift 2
            ;;
        --body)
            BODY="$2"
            shift 2
            ;;
        --body-file)
            BODY_FILE="$2"
            shift 2
            ;;
        --branch)
            BRANCH="$2"
            shift 2
            ;;
        --max-runtime)
            MAX_RUNTIME="$2"
            shift 2
            ;;
        --goal)
            GOAL=true
            shift
            ;;
        --goal-max-turns)
            GOAL_MAX_TURNS="$2"
            shift 2
            ;;
        --priority)
            PRIORITY="$2"
            shift 2
            ;;
        --idempotency-key)
            IDEMPOTENCY_KEY="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

if [ $# -ne 1 ]; then
    usage >&2
    exit 1
fi

TITLE="$1"
REPO_ROOT="$(git rev-parse --show-toplevel)"
CURRENT_BRANCH="$(git branch --show-current || true)"

if [ -z "$BRANCH" ]; then
    SLUG="$(slugify "$TITLE")"
    if [ -z "$SLUG" ]; then
        SLUG="codex_task"
    fi
    BRANCH="apostolos/hermes_${SLUG}_$(date -u +%Y%m%d%H%M%S)_$$"
fi

if [ -n "$BODY_FILE" ]; then
    BODY_FROM_FILE="$(cat "$BODY_FILE")"
    if [ -n "$BODY" ]; then
        BODY="${BODY}"$'\n\n'"${BODY_FROM_FILE}"
    else
        BODY="$BODY_FROM_FILE"
    fi
fi

TASK_BODY=$(cat <<EOF
Repository: $REPO_ROOT
Base branch at task creation: ${CURRENT_BRANCH:-unknown}
Target branch: $BRANCH

Use the Hermes Codex PR lane:
- Hermes owns Kanban lifecycle, final verification, and handoff.
- Codex CLI may implement only inside the assigned isolated worktree.
- Review git status, diff stat, and diff before accepting Codex work.
- Run relevant repository checks from Hermes after Codex exits.
- Open a GitHub PR when the change is ready and block with review-required metadata.

Acceptance criteria:
${BODY:-Use the task title as the acceptance criteria. Clarify by blocking if this is not enough to implement safely.}
EOF
)

cmd=(hermes)
if [ -n "$BOARD" ]; then
    cmd+=(kanban --board "$BOARD" create "$TITLE")
else
    cmd+=(kanban create "$TITLE")
fi

cmd+=(--assignee "$ASSIGNEE")
cmd+=(--workspace worktree)
cmd+=(--branch "$BRANCH")
cmd+=(--body "$TASK_BODY")
cmd+=(--max-runtime "$MAX_RUNTIME")
cmd+=(--skill codex)
cmd+=(--skill github-pr-workflow)

if [ "$GOAL" = true ]; then
    cmd+=(--goal)
fi
if [ -n "$GOAL_MAX_TURNS" ]; then
    cmd+=(--goal-max-turns "$GOAL_MAX_TURNS")
fi
if [ -n "$PRIORITY" ]; then
    cmd+=(--priority "$PRIORITY")
fi
if [ -n "$IDEMPOTENCY_KEY" ]; then
    cmd+=(--idempotency-key "$IDEMPOTENCY_KEY")
fi

"${cmd[@]}"
